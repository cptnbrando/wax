# WAXONWAX API ENVIRONMENT VARIABLES EXAMPLE
# Rename this file to .env and configure keys to enable integrations.

# ==============================================================================
# 1. OFFICIAL REDDIT DEVVIT PLATFORM WEBHOOK
# ==============================================================================
# Secret authorization token used to validate incoming triggers from your Devvit app.
DEVVIT_WEBHOOK_SECRET=devvit_sec_8a3f902bc91b

# ==============================================================================
# 2. SPOTIFY API INTEGRATION (STREAMING SYNC & AUTOCOMPLETE)
# ==============================================================================
# Obtain these from: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# ==============================================================================
# 3. APPLE MUSIC API INTEGRATION (STREAMING SYNC & AUTOCOMPLETE)
# ==============================================================================
# Obtain Developer Token and Music User Token from Apple Developer Console.
APPLE_MUSIC_DEVELOPER_TOKEN=your_apple_music_developer_jwt_token_here
APPLE_MUSIC_USER_TOKEN=your_apple_music_user_music_token_here

# ==============================================================================
# 4. DISCOGS API INTEGRATION (COLLECTION SYNC via OAuth 1.0a)
# ==============================================================================
# Configure Discogs Application Consumer keys for OAuth authentication.
DISCOGS_CONSUMER_KEY=your_discogs_consumer_key_here
DISCOGS_CONSUMER_SECRET=your_discogs_consumer_secret_here
DISCOGS_REQUEST_TOKEN_URL=https://api.discogs.com/oauth/request_token
DISCOGS_AUTHORIZE_URL=https://www.discogs.com/oauth/authorize
DISCOGS_ACCESS_TOKEN_URL=https://api.discogs.com/oauth/access_token

# ==============================================================================
# 5. TWILIO API INTEGRATION (SMS DROP ROUTING ENGINE)
# ==============================================================================
# Obtain credentials from: https://www.twilio.com/console
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_SENDER_PHONE_NUMBER=+15559329290
TWILIO_RECIPIENT_PHONE_NUMBER=+15551234567

# ==============================================================================
# 6. RESEND API INTEGRATION (EMAIL DROP ROUTING ENGINE)
# ==============================================================================
# Obtain API key from: https://resend.com/api-keys
RESEND_API_KEY=re_1234567890abcdef
RESEND_SENDER_EMAIL=alerts@waxonwax.io
RESEND_RECIPIENT_EMAIL=digging@crateking.com
